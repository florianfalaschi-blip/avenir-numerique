# =====================================================
# AVENIR NUMÉRIQUE — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# NE JAMAIS commiter le fichier .env.local sur Git
# =====================================================

# --- SUPABASE ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxx

# --- STRIPE ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# --- RESEND (emails transactionnels) ---
RESEND_API_KEY=re_xxxx

# --- SENTRY ---
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@sentry.io/xxxx

# --- APP ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# --- ADMIN APP SPÉCIFIQUE ---
# (dans apps/admin/.env.local)

# --- WEB APP SPÉCIFIQUE ---
# (dans apps/web/.env.local)
