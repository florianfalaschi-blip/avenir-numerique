# ============================================================
# AVENIR NUMERIQUE - .gitignore
# ============================================================

# === Dépendances ===
node_modules/
.pnpm-store/
.yarn/
package-lock.json
yarn.lock

# === Build & cache ===
.next/
out/
dist/
build/
.turbo/
.swc/
*.tsbuildinfo

# === Variables d'environnement (SENSIBLES !) ===
.env
.env.local
.env.*.local
.env.development
.env.production
*.env

# === IDE / Editeur ===
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# === OS ===
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# === Logs ===
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# === Tests ===
coverage/
.nyc_output/
test-results/
playwright-report/
playwright/.cache/

# === Supabase ===
supabase/.branches/
supabase/.temp/

# === Sentry ===
.sentryclirc

# === Autres ===
*.tgz
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# === Fichiers temporaires utilisateur ===
*.tmp
*.bak
*.backup
*.old
